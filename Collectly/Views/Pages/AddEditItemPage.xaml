<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Collectly.ViewModels"
             x:Class="Collectly.Views.Pages.AddEditItemPage"
             x:DataType="vm:AddEditItemViewModel"
             Title="{Binding Title}">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">
            <Label Text="URL" FontSize="14" FontAttributes="Bold"/>
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0" Text="{Binding Url}" Placeholder="https://..."
                       Keyboard="Url" MaxLength="2048"/>
                <Button Grid.Column="1" Text="🔗"
                        Command="{Binding OpenUrlCommand}"
                        WidthRequest="44" HeightRequest="44"
                        ToolTipProperties.Text="Open in browser"/>
                <Button Grid.Column="2" Text="🔍"
                        Command="{Binding ExtractMetadataCommand}"
                        IsEnabled="{Binding IsExtracting, Converter={StaticResource InvertedBoolConverter}}"
                        WidthRequest="44" HeightRequest="44"
                        ToolTipProperties.Text="Extract metadata"/>
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsExtracting}" IsVisible="{Binding IsExtracting}"
                               HeightRequest="20"/>

            <Label Text="Title" FontSize="14" FontAttributes="Bold"/>
            <Entry Text="{Binding ItemTitle}" Placeholder="Product name" MaxLength="200"/>

            <Label Text="Store" FontSize="14" FontAttributes="Bold"/>
            <Entry Text="{Binding StoreName}" Placeholder="Amazon, Etsy, etc." MaxLength="100"/>

            <Label Text="Price" FontSize="14" FontAttributes="Bold"/>
            <Entry Text="{Binding Price}" Placeholder="0.00" Keyboard="Numeric"/>

            <Label Text="Priority" FontSize="14" FontAttributes="Bold"/>
            <Picker ItemsSource="{Binding Priorities}" SelectedItem="{Binding Priority}"/>

            <Label Text="Tags" FontSize="14" FontAttributes="Bold"/>
            <Entry Text="{Binding Tags}" Placeholder="gift, tech, home" MaxLength="500"/>

            <Label Text="Notes" FontSize="14" FontAttributes="Bold"/>
            <Editor Text="{Binding Notes}" Placeholder="Optional notes..."
                    MaxLength="2000" HeightRequest="80" AutoSize="TextChanges"/>

            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                    HeightRequest="120"
                    IsVisible="{Binding ImageUrl, Converter={StaticResource IsNotNullConverter}}"
                    BackgroundColor="{StaticResource Gray100}">
                <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,20,0,0">
                <Button Grid.Column="0" Text="Cancel"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="1" Text="Save"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        Command="{Binding SaveCommand}"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
