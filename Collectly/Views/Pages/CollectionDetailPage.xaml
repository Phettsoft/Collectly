<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Collectly.ViewModels"
             x:Class="Collectly.Views.Pages.CollectionDetailPage"
             x:DataType="vm:CollectionDetailViewModel"
             Title="{Binding Title}">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto,Auto">
            <Label Grid.Column="0" Text="{Binding Title}" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
            <Button Grid.Column="1" Text="📤" BackgroundColor="Transparent"
                    Command="{Binding ShareCollectionCommand}" VerticalOptions="Center"
                    ToolTipProperties.Text="Share list"/>
            <Button Grid.Column="2" Text="✏️" BackgroundColor="Transparent"
                    Command="{Binding EditCollectionCommand}" VerticalOptions="Center"/>
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="*" Padding="16">
        <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
            <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" Padding="40">
                        <Label Text="🛒" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="No items yet" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Tap + to add items or share from other apps"
                               FontSize="14" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Share" BackgroundColor="{StaticResource Primary}"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CollectionDetailViewModel}}, Path=ShareItemCommand}"
                                               CommandParameter="{Binding}"/>
                                    <SwipeItem Text="Delete" BackgroundColor="{StaticResource Error}"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CollectionDetailViewModel}}, Path=DeleteItemCommand}"
                                               CommandParameter="{Binding}"/>
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Padding="12" Margin="0,4"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                    StrokeThickness="1"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CollectionDetailViewModel}}, Path=OpenItemCommand}"
                                        CommandParameter="{Binding}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="12">
                                    <Border Grid.Column="0" StrokeShape="RoundRectangle 8"
                                            StrokeThickness="0" WidthRequest="60" HeightRequest="60"
                                            BackgroundColor="{StaticResource Gray100}">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill"
                                               WidthRequest="60" HeightRequest="60"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" MaxLines="2"/>
                                        <Label Text="{Binding StoreName}" FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                               IsVisible="{Binding StoreName, Converter={StaticResource IsNotNullConverter}}"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="4">
                                        <Label Text="{Binding Price, StringFormat='${0:F2}'}" FontSize="14"
                                               FontAttributes="Bold" TextColor="{StaticResource Primary}"
                                               HorizontalOptions="End"/>
                                        <Button Text="{Binding IsPurchased, Converter={StaticResource PurchasedIconConverter}}"
                                                FontSize="16" BackgroundColor="Transparent" Padding="0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CollectionDetailViewModel}}, Path=TogglePurchasedCommand}"
                                                CommandParameter="{Binding}" HorizontalOptions="End"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- FAB -->
        <Button Text="+"
                FontSize="24" FontAttributes="Bold"
                WidthRequest="60" HeightRequest="60" CornerRadius="30"
                BackgroundColor="{StaticResource Primary}" TextColor="White"
                HorizontalOptions="End" VerticalOptions="End" Margin="0,0,8,8"
                Command="{Binding AddItemCommand}"
                Shadow="{Shadow Brush=Black, Offset='2,4', Radius=8, Opacity=0.3}"/>
    </Grid>
</ContentPage>
