<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:Collectly.Views.Converters"
             x:Class="Collectly.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:IsNotNullConverter x:Key="IsNotNullConverter"/>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
            <converters:PurchasedIconConverter x:Key="PurchasedIconConverter"/>
            <converters:BoolToCreateTextConverter x:Key="BoolToCreateTextConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
