<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:Collectly.Views.Pages"
       x:Class="Collectly.AppShell"
       FlyoutBehavior="Disabled"
       Title="Collectly">

    <TabBar>
        <ShellContent Title="Home" Icon="{OnPlatform iOS=house, Default=''}"
                      ContentTemplate="{DataTemplate pages:DashboardPage}" Route="dashboard"/>
        <ShellContent Title="Settings" Icon="{OnPlatform iOS=gear, Default=''}"
                      ContentTemplate="{DataTemplate pages:SettingsPage}" Route="settings"/>
        <ShellContent Title="About" Icon="{OnPlatform iOS=info.circle, Default=''}"
                      ContentTemplate="{DataTemplate pages:AboutPage}" Route="about"/>
    </TabBar>

</Shell>
