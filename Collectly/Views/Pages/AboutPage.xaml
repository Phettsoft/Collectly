<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Collectly.ViewModels"
             x:Class="Collectly.Views.Pages.AboutPage"
             x:DataType="vm:AboutViewModel"
             Title="{Binding Title}">

    <VerticalStackLayout Padding="40" Spacing="16" VerticalOptions="Center" HorizontalOptions="Center">
        <Image Source="appicon.png" HeightRequest="96" WidthRequest="96"
               HorizontalOptions="Center"/>
        <Label Text="{Binding AppName}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Label Text="{Binding Version}" FontSize="18" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
        <Label Text="{Binding Description}" FontSize="14" HorizontalOptions="Center"
               HorizontalTextAlignment="Center" MaxLines="3"
               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>

        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                 Margin="0,20"/>

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="20">
            <Label Grid.Row="0" Grid.Column="0" Text="Application Version" FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Version}" FontSize="13" FontAttributes="Bold"/>
            <Label Grid.Row="1" Grid.Column="0" Text="Build Date" FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
            <Label Grid.Row="1" Grid.Column="1" Text="{Binding BuildDate}" FontSize="13" FontAttributes="Bold"/>
        </Grid>

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" RowSpacing="8" ColumnSpacing="20" Margin="0,8,0,0">
            <Label Grid.Row="0" Grid.Column="0" Text="DB Schema Version" FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
            <Label Grid.Row="0" Grid.Column="1" Text="{Binding SchemaVersion}" FontSize="13" FontAttributes="Bold"/>
        </Grid>

        <Label Text="Made with ❤️ for organized shoppers"
               FontSize="12" HorizontalOptions="Center" Margin="0,30,0,0"
               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"/>
    </VerticalStackLayout>
</ContentPage>
