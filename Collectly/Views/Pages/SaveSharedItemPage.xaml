<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Collectly.ViewModels"
             x:Class="Collectly.Views.Pages.SaveSharedItemPage"
             x:DataType="vm:SaveSharedItemViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">

        <!-- Top action bar - always visible -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*" ColumnSpacing="12"
              Padding="16,12" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
            <Button Grid.Column="0" Text="Cancel"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    Command="{Binding CancelCommand}"
                    HeightRequest="44"/>
            <Button Grid.Column="1" Text="Save"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    Command="{Binding SaveCommand}"
                    HeightRequest="44"/>
        </Grid>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1" Padding="20,12,20,20">
            <VerticalStackLayout Spacing="14">

                <Label Text="Save to Collection" FontSize="18" FontAttributes="Bold"/>

                <!-- Collection picker + New List button -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Picker Grid.Column="0"
                            ItemsSource="{Binding Collections}"
                            SelectedItem="{Binding SelectedCollection}"
                            ItemDisplayBinding="{Binding Name}"
                            Title="Select collection"
                            IsVisible="{Binding IsCreatingNewList, Converter={StaticResource InvertedBoolConverter}}"/>
                    <Entry Grid.Column="0"
                           Text="{Binding NewCollectionName}"
                           Placeholder="New list name..."
                           MaxLength="200"
                           IsVisible="{Binding IsCreatingNewList}"/>
                    <Button Grid.Column="1"
                            Text="{Binding IsCreatingNewList, Converter={StaticResource BoolToCreateTextConverter}}"
                            Command="{Binding CreateNewListCommand}"
                            HeightRequest="44" FontSize="13" Padding="12,0"/>
                </Grid>

                <!-- Cancel new list -->
                <Label Text="✕ Cancel new list" FontSize="12"
                       TextColor="{StaticResource Primary}"
                       IsVisible="{Binding IsCreatingNewList}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CancelNewListCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="⚠️ This item may already exist in this collection"
                       TextColor="{StaticResource Warning}" FontSize="12"
                       IsVisible="{Binding IsDuplicate}"/>

                <ActivityIndicator IsRunning="{Binding IsExtracting}" IsVisible="{Binding IsExtracting}"
                                   HeightRequest="20"/>

                <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                        HeightRequest="150"
                        IsVisible="{Binding ImageUrl, Converter={StaticResource IsNotNullConverter}}"
                        BackgroundColor="{StaticResource Gray100}">
                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                </Border>

                <Label Text="Title" FontSize="14" FontAttributes="Bold"/>
                <Entry Text="{Binding ItemTitle}" Placeholder="Item title" MaxLength="200"/>

                <Label Text="URL" FontSize="14" FontAttributes="Bold"/>
                <Label Text="{Binding SharedUrl}" FontSize="12"
                       TextColor="{StaticResource Primary}"
                       TextDecorations="Underline"
                       LineBreakMode="TailTruncation" MaxLines="2">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenUrlCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="Store" FontSize="14" FontAttributes="Bold"/>
                <Entry Text="{Binding StoreName}" Placeholder="Store name" MaxLength="100" IsReadOnly="True"/>

                <Label Text="Price" FontSize="14" FontAttributes="Bold"/>
                <Entry Text="{Binding Price}" Placeholder="0.00" Keyboard="Numeric"/>

                <Label Text="Notes" FontSize="14" FontAttributes="Bold"/>
                <Editor Text="{Binding Notes}" Placeholder="Add a note..."
                        MaxLength="2000" HeightRequest="80" AutoSize="TextChanges"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
